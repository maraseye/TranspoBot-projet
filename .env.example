# ─── Base de données ────────────────────────────────────────────────────────
# En local sans Docker : DB_HOST=localhost avec MySQL qui tourne sur la machine.
# Avec docker-compose du projet : les services reçoivent DB_HOST=db automatiquement.
DB_HOST=localhost
DB_NAME=transpobot
DB_USER=transpobot_user
DB_PASSWORD=ChangeMe123!
DB_ROOT_PASSWORD=RootPassChangeMe!

# ─── LLM (OpenAI, Groq, ou compatible OpenAI : Ollama, vLLM, etc.) ─────────
# Une seule clé suffit selon le fournisseur. Ordre lu par l’appli : LLM_API_KEY → GROQ_API_KEY → OPENAI_API_KEY.

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-VOTRE_CLE_ICI

# Groq (API compatible OpenAI) — https://console.groq.com/keys
# Exemple .env pour n’utiliser que Groq (laisser OPENAI vide ou commenter) :
# GROQ_API_KEY=gsk_VOTRE_CLE_ICI
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# Modèle (OpenAI : gpt-4o-mini, … | Groq : llama-3.3-70b-versatile, mixtral-8x7b-32768, … | Ollama : mistral, …)
LLM_MODEL=gpt-4o-mini

# URL sans slash final ; l’appli appelle …/chat/completions
LLM_BASE_URL=https://api.openai.com/v1

# Optionnel : une seule variable pour forcer la clé (prioritaire sur GROQ_API_KEY et OPENAI_API_KEY)
# LLM_API_KEY=

# --- Exemple Ollama sur la machine hôte (depuis un conteneur Docker Windows/Mac) ---
# OPENAI_API_KEY=ollama
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_MODEL=mistral

# --- Exemple Ollama en local (backend lancé sur le même PC que Ollama) ---
# OPENAI_API_KEY=ollama
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=mistral

# Clé factice pour Ollama si besoin (défaut : ollama quand LLM_BASE_URL n’est pas OpenAI)
# LLM_OLLAMA_DUMMY_KEY=ollama

# Nombre max de lignes JSON envoyées au modèle pour la synthèse (défaut 40)
# LLM_MAX_SUMMARY_ROWS=40

# ─── Traefik / HTTPS (déploiement) ───────────────────────────────────────────
DOMAIN=votre-domaine.com
ACME_EMAIL=votre@email.com
